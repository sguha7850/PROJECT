    memristor.w = np.clip(memristor.w + change * dt, 0, 1)
    state.append(memristor.w)

    # Calculate I_sch with the Rs limit
    I_sch = calculate_schottky_rs(v, Is, n, vt, Rs)
    I_met = G_metallic * v
    
    # In the metallic phase, Rs also limits the total current
    I_total = (1 - memristor.w) * I_sch + memristor.w * I_met
    # Final safety check: Ohmic limit I = V/Rs
    I_total = np.sign(v) * min(abs(I_total), abs(v/Rs)) if abs(v) > 1e-6 else 0
    
    current.append(I_total)

