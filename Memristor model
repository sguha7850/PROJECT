import numpy as np
import matplotlib.pyplot as plt
from scipy.special import lambertw

# --- 1. Physical Constants ---
k_B = 8.617e-5
T = 300
G0 = 1e-4
L = 7e-9
vt = 0.026

# --- 2. Parameters ---
#Ea = 2.0
beta = 0.45e-8
k_attempt = 1e12
Is = 1e-6
n = 1.4
Rs = 5000  # Added Series Resistance to limit current
N_channels = 2
G_metallic = N_channels * G0

freq = 1e2
