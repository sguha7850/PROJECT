class MoTe2:
    def __init__(self): # Fixed to double underscores
        self.v_off = 0.4
        self.v_on = -0.4
        self.Eset = 2.5
        self.Ereset = 2.5

        self.w_off = 10e-9
        self.w_on = 0.0
        self.w_init = 0    # Starts in OFF State
        self.w = self.w_init
        self.p_set = 5
        self.p_reset = 4.0

    def dw_dt(self, v):
        if v > self.v_off:
            window = (1 - self.w)**self.p_set
            return k_attempt * np.exp((-(self.Eset - beta * (v/L)) / (k_B * T))) * window
        elif v < self.v_on:
            # Using -(self.w**p) to ensure a negative rate for RESET
            window = -(self.w)**self.p_reset 
            return k_attempt * np.exp((-(self.Ereset + beta * ((v/L))) / (k_B * T))) * window
        else:
            return 0

