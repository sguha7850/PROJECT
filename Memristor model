def calculate_schottky_rs(V, Is, n, vt, Rs):
    """Calculates Schottky current limited by Rs using Lambert W."""
    if V <= 0: return Is * (np.exp(V / (n * vt)) - 1) # Reverse bias is usually safe
    # Analytical solution for I = Is * (exp((V - I*Rs) / (n*vt)) - 1)
    exponent_arg = (V + Is * Rs) / (n * vt)
    w_arg = (Is * Rs / (n * vt)) * np.exp(exponent_arg)
    I = (n * vt / Rs) * np.real(lambertw(w_arg)) - Is
    return I

class MoTe2:
    def __init__(self):
        self.v_off = 0.1
        self.v_on = -0.1
        self.w = 0.0
        self.Eset=1.8
        self.Ereset=1.9

    def dw_dt(self, v):
        #beta_set = 0.5e-8
        #beta_reset = 0.45e-8 

        if v > self.v_off:
            return k_attempt * np.exp(-(self.Eset - beta * (v/L)) / (k_B * T)) * (1 - self.w)
        elif v < self.v_on:
            return k_attempt * np.exp(-(self.Ereset - beta * np.abs((v/L))) / (k_B * T)) * (-self.w)
        return 0

