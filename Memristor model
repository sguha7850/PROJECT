Is = 5e-6
n_set=8.5
n_reset=8
vt = 0.026

# Metallic Parameters (Final 1T' Phase)
N_channels = 2
G_metallic = N_channels * G0
s_set=5
s_reset=1

freq = 1e3                          # 1 kHz
t = np.linspace(0, 1/freq, 25000)   # 2 full cycles
V_max = 1.0                         # 2V Amplitude
V_signal = V_max * np.sin(2 * np.pi * freq * t)
dt = t[1] - t[0]

class MoTe2:
    def __init__(self): # Fixed to double underscores
        self.v_off = 0.0
        self.v_on = -0.4
        self.Eset = 1.75
        self.Ereset = 1.63

        self.w_off = 10e-9
        self.w_on = 0.0
        self.w_init = 0    # Starts in OFF State
        self.w = self.w_init
        self.p_set = 3
        self.p_reset = 0.3

